views:
  - type: table
    name: Table
    filters:
      and:
        - file.inFolder("Main/Mods")
    order:
      - file.name
      - Integration Phase
      - Install Location
      - ModCategory
      - Dependencies
      - Mod Version
      - QA Final
    columnSize:
      file.name: 330
      note.Integration Phase: 149
      note.Install Location: 135
      note.ModCategory: 158
      note.Dependencies: 254
      note.Mod Version: 135
